// ميزة التنفيذ: تشغيل الكود داخل بيئة الـ Shell
private async void OnRunClicked(object sender, EventArgs e)
{
string codeToRun = CodeEditor.Text;

if (string.IsNullOrEmpty(codeToRun))
return;

OutputPanel.IsVisible = true;
TerminalOutput.Text = "Compiling and Running...\n";

try
{
// محاكاة تشغيل الكود في البيئة المتاحة
// في C# Shell، نقوم عادةً بكتابة ملف مؤقت وتشغيله
await Task.Run(() => ExecuteCode(codeToRun));
}
catch (Exception ex)
{
TerminalOutput.Text += $"❌ Error: {ex.Message}\n";
}
}

