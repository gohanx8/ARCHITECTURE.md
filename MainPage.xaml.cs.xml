// ميزة الإصلاح الذكي (Smart Fix)
private void OnFixErrorClicked(object sender, EventArgs e)
{
// خوارزمية بسيطة لإصلاح الأخطاء الشائعة (مثل نقص الفاصلة المنقوطة)
if (CodeEditor.Text.Contains("Console.WriteLine") && !CodeEditor.Text.Contains(";"))
{
CodeEditor.Text = CodeEditor.Text.Replace("Console.WriteLine(", "Console.WriteLine(; // ملاحظة: هذا مثال بسيط، في الوضع الحقيقي نستخدم Regex أو LSP
}

DisplayAlert("Smart Fix", "Common syntax errors repaired.", "OK");
}

private void OnCodeChanged(object sender, TextChangedEventArgs e)
{
